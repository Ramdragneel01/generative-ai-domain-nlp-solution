MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
FAITHFULNESS_THRESHOLD=0.6
APP_NAME=hallucination-lens
APP_VERSION=0.2.0
MIN_THRESHOLD=0.3
MAX_THRESHOLD=0.9
MAX_BATCH_ITEMS=50
MAX_CONTEXT_CHARS=50000
MAX_RESPONSE_CHARS=50000
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=1.0
RATE_LIMIT_REDIS_KEY_PREFIX=hallucination-lens:rate-limit
MAX_REQUEST_BYTES=1048576
TRUSTED_HOSTS=127.0.0.1,localhost
ENABLE_GZIP=true
GZIP_MINIMUM_SIZE=1024
PRELOAD_MODEL_ON_STARTUP=false
ENABLE_HSTS=false
GATEWAY_AUTH_ENABLED=false
GATEWAY_AUTH_HEADER=X-Gateway-Auth
GATEWAY_AUTH_SECRET=
GATEWAY_PRINCIPAL_HEADER=X-Principal-Id
REQUIRE_GATEWAY_PRINCIPAL=false
CORS_ORIGINS=http://127.0.0.1:4176,http://localhost:4176
API_KEY=
